# portfolio-backend — environment variables
# Copy this to .env and fill in real values. Never commit .env.

# Server
PORT=3001
# Set to "production" on VPS — enables Secure flag on HttpOnly auth cookie
NODE_ENV=production

# SQLite database path (relative to project root or absolute)
DATABASE_PATH=./data/portfolio.db

# Authentik OIDC — JWKS endpoint for JWT validation
# JWKS: https://auth.nammon.men/application/o/portfolio/.well-known/jwks.json
AUTHENTIK_JWKS_URL=https://auth.nammon.men/application/o/portfolio/.well-known/jwks.json

# Authentik issuer (must match 'iss' claim in access tokens; usually includes trailing slash)
AUTHENTIK_ISSUER=https://auth.nammon.men/application/o/portfolio/

# Authentik Client ID (must match 'aud' claim in access tokens)
AUTHENTIK_CLIENT_ID=portfolio

# Admin email — this address is granted admin access regardless of group membership
ADMIN_EMAIL=admin@nammon.men

# Static fallback token for service-to-service calls (e.g. n4mmon-dashboard)
# Leave blank to disable the static token fallback
ADMIN_TOKEN=

# CORS — allowed origin for browser requests
ALLOWED_ORIGIN=https://nammon.men

# Upload directory for avatar and other media (absolute or relative to backend root)
# On VPS this points to the nginx-served uploads directory
UPLOAD_DIR=../www/nammon.men/about/assets/uploads
